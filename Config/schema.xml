<?xml version="1.0" encoding="UTF-8"?>
<database defaultIdMethod="native" name="TheliaMain" namespace="CustomFields\Model"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="../../../vendor/thelia/propel/resources/xsd/database.xsd" >
    <!--
    See propel documentation on http://propelorm.org for all information about schema file

    <table name="product_rel">
        <column autoIncrement="true" name="id" primaryKey="true" required="true" type="INTEGER" />
        <column defaultValue="0" name="visible" required="true" type="TINYINT" />
        <column defaultValue="0" name="position" required="true" type="INTEGER" />
        <column name="title" size="255" type="VARCHAR" />
        <column name="description" type="CLOB" />
        <column name="chapo" type="LONGVARCHAR" />
        <column name="postscriptum" type="LONGVARCHAR" />
        <foreign-key foreignTable="product" name="fk_product_id" onDelete="CASCADE" onUpdate="RESTRICT">
            <reference foreign="id" local="product_id" />
        </foreign-key>
        <behavior name="timestampable" />
        <behavior name="i18n">
            <parameter name="i18n_columns" value="title, description, chapo, postscriptum" />
        </behavior>
    </table>
    -->

    <!-- ===================== -->
    <!-- custom_field_parent    -->
    <!-- ===================== -->
    <table name="custom_field_parent">
        <column name="id"    type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="title" type="VARCHAR" size="255"  required="true"/>
    </table>

    <!-- ===================== -->
    <!-- custom_field           -->
    <!-- ===================== -->
    <table name="custom_field">
        <column name="id"    type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="code"  type="VARCHAR" size="100"  required="true"/>
        <column name="title" type="VARCHAR" size="255"  required="true"/>
        <column name="is_international" type="BOOLEAN" required="true" default="true"/>
        <column name="type"  type="ENUM"    valueSet="text,textarea,wysiwyg,content,category,folder,product,image,repeater,checkbox" required="true" default="text"/>
        <column name="position" type="INTEGER" required="false" default="0"/>
        <column name="custom_field_parent_id" type="INTEGER" required="false"/>

        <!-- No FK on custom_field_parent_id: can reference custom_field_parent.id (grouping)
             OR custom_field.id (repeater sub-field parent) -->

    </table>

    <!-- ===================== -->
    <!-- custom_field_source    -->
    <!-- ===================== -->
    <table name="custom_field_source">
        <column name="custom_field_id" type="INTEGER" required="true" primaryKey="true"/>
        <column name="source"          type="VARCHAR" size="100" required="true" primaryKey="true"/>
        <!-- ex: content, product, ... -->

        <foreign-key foreignTable="custom_field" onDelete="CASCADE" onUpdate="CASCADE">
            <reference local="custom_field_id" foreign="id"/>
        </foreign-key>
    </table>


    <!-- ===================== -->
    <!-- custom_field_value     -->
    <!-- ===================== -->
    <table name="custom_field_value">
        <column name="id"              type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="custom_field_id" type="INTEGER" required="true"/>
        <column name="source"          type="VARCHAR" size="100" required="true"/>
        <column name="source_id"       type="INTEGER"/>
        <column name="repeater_row_id" type="INTEGER" required="false"/>
        <column name="value"           type="LONGVARCHAR"/>
        <column name="simple_value"    type="LONGVARCHAR"/>


        <foreign-key foreignTable="custom_field" onDelete="CASCADE" onUpdate="CASCADE">
            <reference local="custom_field_id" foreign="id"/>
        </foreign-key>

        <!-- Index pour retrouver rapidement toutes les valeurs d'une source donnée -->
        <index name="idx_cfv_source">
            <index-column name="source"/>
            <index-column name="source_id"/>
        </index>

        <!-- Contrainte d'unicité : une seule valeur par champ/source/entité/row -->
        <unique name="uq_cfv_field_source">
            <unique-column name="custom_field_id"/>
            <unique-column name="source"/>
            <unique-column name="source_id"/>
            <unique-column name="repeater_row_id"/>
        </unique>

        <foreign-key foreignTable="custom_field_repeater_row" onDelete="CASCADE" onUpdate="CASCADE">
            <reference local="repeater_row_id" foreign="id"/>
        </foreign-key>

        <behavior name="i18n">
            <parameter name="i18n_columns" value="value" />
        </behavior>
    </table>

    <!-- ===================== -->
    <!-- custom_field_repeater_row    -->
    <!-- ===================== -->
    <table name="custom_field_repeater_row">
        <column name="id"                      type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="custom_field_id"         type="INTEGER" required="true"/>
        <column name="source"                  type="VARCHAR" size="100" required="true"/>
        <column name="source_id"               type="INTEGER"/>
        <column name="parent_repeater_row_id"  type="INTEGER" required="false"/>
        <column name="position"                type="INTEGER" required="true" default="0"/>

        <foreign-key foreignTable="custom_field" onDelete="CASCADE" onUpdate="CASCADE">
            <reference local="custom_field_id" foreign="id"/>
        </foreign-key>

        <foreign-key foreignTable="custom_field_repeater_row" onDelete="CASCADE" onUpdate="CASCADE">
            <reference local="parent_repeater_row_id" foreign="id"/>
        </foreign-key>

        <index name="idx_cfrr_source">
            <index-column name="source"/>
            <index-column name="source_id"/>
            <index-column name="custom_field_id"/>
        </index>
    </table>

    <!-- ===================== -->
    <!-- custom_field_image           -->
    <!-- ===================== -->
    <table name="custom_field_image">
        <column autoIncrement="true" name="id" primaryKey="true" required="true" type="INTEGER" />
        <column name="custom_field_value_id" type="INTEGER" />

        <column name="file" required="true" size="255" type="VARCHAR" />
        <behavior name="timestampable" />
        <foreign-key foreignTable="custom_field_value" onDelete="CASCADE" onUpdate="RESTRICT">
            <reference foreign="id" local="custom_field_value_id" />
        </foreign-key>

    </table>

    <table name="custom_field_option_page">
        <column name="id"    type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="title" type="VARCHAR" size="255" required="true"/>
        <column name="code"  type="VARCHAR" size="100" required="true"/>
        <behavior name="timestampable" />
        <unique>
            <unique-column name="code"/>
        </unique>
    </table>

    <external-schema filename="vendor/thelia/config/schema.xml" referenceOnly="true"/>
</database>
